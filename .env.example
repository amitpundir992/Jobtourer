# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jobtourer"
REDIS_URL="redis://localhost:6379"

# Node Environment
NODE_ENV="development"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Public company job boards (comma-separated identifiers)
GREENHOUSE_BOARD_TOKENS="cloudflare,datadog,mongodb"
LEVER_SITE_NAMES="palantir,spotify,highspot,aircall"

# Authentication
BETTER_AUTH_SECRET="generate-a-random-secret-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (for login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth (for login)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# AI Services (choose at least one)
AI_PROVIDER="openai" # openai, gemini, or claude
OPENAI_API_KEY="sk-..."
GOOGLE_GEMINI_API_KEY="..."
ANTHROPIC_API_KEY="..."

# Gmail API (for email drafts)
GMAIL_CLIENT_ID="your-gmail-client-id"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3000/api/auth/gmail/callback"

# Storage - Cloudflare R2 (recommended)
STORAGE_PROVIDER="r2" # r2 or s3
AWS_ACCESS_KEY_ID="your-r2-access-key"
AWS_SECRET_ACCESS_KEY="your-r2-secret-key"
AWS_REGION="auto"
AWS_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
S3_BUCKET_NAME="jobtourer-resumes"

# Or AWS S3 (alternative)
# STORAGE_PROVIDER="s3"
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="us-east-1"
# S3_BUCKET_NAME="jobtourer-resumes"

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (for notifications)
EMAIL_FROM="noreply@jobtourer.com"
EMAIL_REPLY_TO="support@jobtourer.com"

# Logging
LOG_LEVEL="info" # debug, info, warn, error

# Optional: Trigger.dev (for workflow orchestration)
# TRIGGER_API_KEY="tr_..."
# TRIGGER_API_URL="https://api.trigger.dev"

# Optional: Sentry (for error tracking)
# SENTRY_DSN="https://..."
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"
