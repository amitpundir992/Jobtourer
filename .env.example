# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jobtourer"
REDIS_URL="redis://localhost:6379"

# Node Environment
NODE_ENV="development"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Public company job boards (comma-separated identifiers)
GREENHOUSE_BOARD_TOKENS="cloudflare,datadog,mongodb"
LEVER_SITE_NAMES="palantir,spotify,highspot,aircall"

# Authentication
BETTER_AUTH_SECRET="generate-a-random-secret-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (for login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth (for login)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# AI Services (choose at least one)
AI_PROVIDER="openai" # openai, gemini, or claude
OPENAI_API_KEY="sk-..."
GOOGLE_GEMINI_API_KEY="..."
ANTHROPIC_API_KEY="..."

# Gmail API (for email drafts)
GMAIL_CLIENT_ID="your-gmail-client-id"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3000/api/auth/gmail/callback"

# Private resume storage - Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_RESUME_BUCKET="resumes"

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (for notifications)
EMAIL_FROM="noreply@jobtourer.com"
EMAIL_REPLY_TO="support@jobtourer.com"

# Logging
LOG_LEVEL="info" # debug, info, warn, error

# Trigger.dev workflow orchestration
TRIGGER_SECRET_KEY="tr_dev_..."
TRIGGER_PROJECT_REF="proj_..."
TOKEN_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Optional: Sentry (for error tracking)
# SENTRY_DSN="https://..."
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"
